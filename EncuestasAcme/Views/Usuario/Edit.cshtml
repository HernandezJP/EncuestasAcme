@model EncuestasAcme.ViewModels.UsuarioFormViewModel

@{
    ViewBag.Title = "Editar Usuario";
}

<div class="page-intro">
    <h3>Editar usuario</h3>
    <p>Actualiza la información del usuario.</p>
</div>

<div class="form-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.UpdateDTO.USU_Usuario)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-grid">
            <div class="form-col-6">
                <label class="form-label">Username</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_User_Name, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Nueva contraseña</label>
                @Html.PasswordFor(m => m.UpdateDTO.USU_Password_Hash, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Primer nombre</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_Primer_Nombre, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Segundo nombre</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_Segundo_Nombre, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Primer apellido</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_Primer_Apellido, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Segundo apellido</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_Segundo_Apellido, new { @class = "form-control-custom" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Correo</label>
                @Html.TextBoxFor(m => m.UpdateDTO.USU_Correo_Electronico, new { @class = "form-control-custom", type = "email" })
            </div>

            <div class="form-col-6">
                <label class="form-label">Rol</label>
                @Html.DropDownListFor(m => m.UpdateDTO.ROL_Rol, Model.Roles, "Seleccione", new { @class = "form-control-custom" })
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary-custom">Actualizar</button>
            <a href="@Url.Action("Index", "Usuario")" class="btn btn-outline-custom">Cancelar</a>
        </div>
    }
</div>