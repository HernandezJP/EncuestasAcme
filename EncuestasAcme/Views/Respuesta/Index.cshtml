@model List<EncuestasAcme.DTOs.Respuesta.ResponseRespuestaDTO>

@{
    ViewBag.Title = "Respuestas";
}

<div class="page-intro">
    <h3>Respuestas</h3>
    <p>Visualiza todas las respuestas registradas.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="section-card" style="margin-bottom: 16px; border-left: 4px solid #16a34a;">
        <p>@TempData["Success"]</p>
    </div>
}

<div class="table-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Encuesta</th>
                    <th>Fecha</th>
                    <th>IP</th>
                    <th style="width:120px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RES_Codigo</td>
                            <td>@item.ENC_Nombre</td>
                            <td>@item.RES_Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.RES_IP</td>
                            <td>
                                <div class="actions-container">
                                    <a href="@Url.Action("Detail", "Respuesta", new { id = item.RES_Respuesta })"
                                       class="btn-icon btn-secondary">
                                        <i data-lucide="eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">No hay respuestas registradas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>