<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - AcmeEncuestas</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="app-body">
    <div class="app-shell fixed-layout">
        <aside class="app-sidebar">
            <div class="brand-block">
                <div class="brand-logo">AE</div>
                <div>
                    <h1 class="brand-title">AcmeEncuestas</h1>
                    <p class="brand-subtitle">Panel administrativo</p>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a href="@Url.Action("Index", "Dashboard")" class="nav-item">Dashboard</a>
                <a href="@Url.Action("Index", "TipoCampo")" class="nav-item">Tipo de Campos</a>
                <a href="#" class="nav-item">Resultados</a>
                <a href="#" class="nav-item">Perfil</a>
            </nav>

            <div class="sidebar-card">
                <form action="@Url.Action("Logout", "Auth")" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i data-lucide="log-out"></i>
                        Cerrar sesión
                    </button>
                </form>
            </div>
        </aside>

        <div class="app-main">
            <main class="app-content">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <p>&copy; @DateTime.Now.Year - AcmeEncuestas</p>
            </footer>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>lucide.createIcons();</script>
</body>
</html>